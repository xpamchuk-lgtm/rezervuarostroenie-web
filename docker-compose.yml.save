services:
  backend:
    build: ./backend
    restart: unless-stopped
    ports:
      - "8000:8000"
  frontend:
    build: ./frontend
    restart: unless-stopped
  nginx:
    image: nginx:alpine
    restart: unless-stopped
    ports:
      - "80:80"
    volumes:
      - ./infra/nginx.conf:/etc/nginx/conf.d/default.conf:ro
    depends_on:
      - backend
      - frontend
